.DS_Store
nvinfo/

# nvim is tracked by this repo.
nvim-lazy/
nvim.backup/

# zsh: history, generated completion cache, local-only overrides
zsh/.zsh_history
zsh/.zcompdump*
zsh/.zcompcache/
zsh/.zsh_sessions/
zsh/.zshrc.local

# herdr runtime logs
herdr/*.log

# atuin runtime lives in ~/.local/share/atuin and ~/.atuin/logs
