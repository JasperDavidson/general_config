# --- Core Shell ---
command = /bin/zsh

# --- Neutral Transparency & Blur / Theming ---
# background = #0d0d0d
#background-opacity = 0.85
#background-blur = true
theme = Kanso Zen

# --- Window Layout ---
window-padding-x = 14
window-padding-y = 14
macos-titlebar-style = tabs

# --- Typography ---
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# --- SSH ---
shell-integration-features = ssh-env
